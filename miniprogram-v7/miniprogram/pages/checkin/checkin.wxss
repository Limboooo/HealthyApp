.streak-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-top: 28rpx; }
.streak-card { display: flex; min-height: 138rpx; flex-direction: column; align-items: center; justify-content: center; }
.streak-value { color: var(--color-primary); font-size: 42rpx; font-weight: 800; }
.streak-label { margin-top: 8rpx; color: var(--color-muted); font-size: 19rpx; }
.calendar { margin-top: 20rpx; padding: 24rpx 18rpx 20rpx; }
.calendar-head { display: flex; align-items: center; justify-content: space-between; padding: 0 8rpx 18rpx; }
.month-button { width: 64rpx; height: 60rpx; margin: 0; padding: 0; border-radius: 16rpx; color: var(--color-primary); background: var(--color-primary-soft); font-size: 42rpx; line-height: 56rpx; }
.month-button.disabled { color: #b9c0bc; background: #f0f2f0; }
.month-label { font-size: 27rpx; font-weight: 720; }
.week-row, .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.week-row text { padding: 10rpx 0 14rpx; color: var(--color-muted); text-align: center; font-size: 19rpx; }
.calendar-cell { position: relative; display: flex; height: 84rpx; align-items: center; justify-content: center; border-radius: 50%; font-size: 22rpx; }
.calendar-cell.is-today { box-shadow: inset 0 0 0 2rpx var(--color-primary); color: var(--color-primary); font-weight: 700; }
.calendar-cell.is-checked { color: #fff; background: var(--color-primary); }
.calendar-cell.is-future { color: #c6ccc8; }
.check-dot { position: absolute; bottom: 7rpx; width: 5rpx; height: 5rpx; border-radius: 50%; background: #fff; }
.task-row { display: flex; align-items: center; margin-bottom: 12rpx; padding: 22rpx; }
.task-done { border-color: #b5d5c6; background: #edf6f1; }
.task-check { display: flex; width: 42rpx; height: 42rpx; align-items: center; justify-content: center; margin-right: 18rpx; border: 2rpx solid #aec3b9; border-radius: 12rpx; color: #fff; background: #fff; font-size: 22rpx; }
.task-done .task-check { border-color: var(--color-primary); background: var(--color-primary); }
.button-complete { background: #7da393; }
.badge-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; }
.badge { display: flex; min-height: 136rpx; align-items: center; padding: 20rpx; opacity: .58; }
.badge-unlocked { border-color: #bad7c9; background: #eef6f2; opacity: 1; }
.badge-mark { display: flex; width: 62rpx; height: 62rpx; flex: 0 0 auto; align-items: center; justify-content: center; border-radius: 50%; color: var(--color-muted); background: #e7ebe8; font-size: 24rpx; font-weight: 800; }
.badge-unlocked .badge-mark { color: #fff; background: var(--color-primary); }
.badge-label { margin-left: 14rpx; font-size: 22rpx; font-weight: 650; }
