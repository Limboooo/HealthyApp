.food-page { padding-bottom: 60rpx; }
.photo-card { position: relative; display: flex; min-height: 340rpx; align-items: center; justify-content: center; margin-top: 28rpx; overflow: hidden; border-style: dashed; }
.meal-image { position: absolute; width: 100%; height: 100%; }
.photo-empty { display: flex; flex-direction: column; align-items: center; padding: 40rpx; text-align: center; }
.camera-mark { display: flex; width: 82rpx; height: 82rpx; align-items: center; justify-content: center; border-radius: 26rpx; color: #fff; background: var(--color-primary); font-size: 21rpx; font-weight: 750; }
.photo-title { margin-top: 20rpx; font-size: 28rpx; font-weight: 720; }
.photo-copy { margin-top: 9rpx; color: var(--color-muted); font-size: 21rpx; line-height: 1.5; }
.photo-hover { border-color: var(--color-primary); background: #f0f6f3; }
.template-button { width: 100%; margin-top: 14rpx; }
.analysis-state { display: flex; align-items: center; margin-top: 24rpx; padding: 28rpx; }
.loading-dot { width: 34rpx; height: 34rpx; margin-right: 20rpx; border: 6rpx solid #cae0d5; border-top-color: var(--color-primary); border-radius: 50%; animation: spin .8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.analysis-title { font-size: 26rpx; font-weight: 720; }
.analysis-copy { margin-top: 6rpx; color: var(--color-muted); font-size: 20rpx; }
.macro-grid { display: grid; grid-template-columns: repeat(4, 1fr); padding: 24rpx 8rpx; }
.macro-grid > view { display: flex; min-width: 0; flex-direction: column; align-items: center; border-right: 1rpx solid var(--color-line); }
.macro-grid > view:last-child { border-right: 0; }
.macro-value { font-size: 29rpx; font-weight: 780; }
.macro-label { margin-top: 7rpx; color: var(--color-muted); font-size: 17rpx; }
.food-card { margin-top: 14rpx; padding: 24rpx; }
.food-head { display: flex; align-items: center; justify-content: space-between; }
.food-name { width: 360rpx; height: 52rpx; font-size: 27rpx; font-weight: 730; }
.confidence { color: var(--color-muted); font-size: 18rpx; }
.food-meta { margin-top: 8rpx; color: var(--color-muted); font-size: 20rpx; }
.food-controls { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; }
.portion-control { display: flex; align-items: center; overflow: hidden; border: 1rpx solid #d4ded8; border-radius: 14rpx; }
.portion-control button { width: 62rpx; height: 58rpx; margin: 0; padding: 0; color: var(--color-primary); background: #f2f6f3; font-size: 26rpx; line-height: 58rpx; }
.portion-control text { min-width: 92rpx; text-align: center; font-size: 21rpx; }
.cooking-picker { padding: 16rpx 18rpx; border-radius: 14rpx; color: var(--color-primary); background: var(--color-primary-soft); font-size: 21rpx; }
.meal-select { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; padding: 24rpx; font-size: 24rpx; }
.meal-picker { color: var(--color-primary); font-weight: 700; }
.save-button { margin-top: 16rpx; }
